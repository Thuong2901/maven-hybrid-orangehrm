<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="OrangeHRM-UI Automation Testing" verbose="1">
    <listeners>
        <listener class-name="core.MethodListener"></listener>
        <listener class-name="jiraConfigs.JiraListener"></listener>
    </listeners>
    <parameter name="appUrl" value="http://localhost:88/orangehrm/orangehrm-5.7"></parameter>

    <test name="Run on FIREFOX browser">
        <parameter name="browser" value="Firefox"/>
        <classes>
            <class name="com.orangeHRM.Level_05_Page_Factory"/>
        </classes>
    </test>

</suite>